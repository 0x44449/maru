{
  "$schema": "https://atena.dev/design-tokens.schema.json",
  "name": "Atena Design System",
  "version": "1.0.0",

  "color": {
    "primary": {
      "50": "#f5f3ff",
      "100": "#ede9fe",
      "200": "#ddd6fe",
      "300": "#c4b5fd",
      "400": "#a78bfa",
      "500": "#8b5cf6",
      "600": "#7c3aed",
      "700": "#6d28d9",
      "800": "#5b21b6",
      "900": "#4c1d95",
      "950": "#2e1065"
    },
    "neutral": {
      "0": "#ffffff",
      "50": "#fafafa",
      "100": "#f5f5f5",
      "200": "#e5e5e5",
      "300": "#d4d4d4",
      "400": "#a3a3a3",
      "500": "#737373",
      "600": "#525252",
      "700": "#404040",
      "800": "#262626",
      "900": "#171717",
      "950": "#0a0a0a"
    },
    "semantic": {
      "success": {
        "light": "#dcfce7",
        "default": "#22c55e",
        "dark": "#15803d"
      },
      "warning": {
        "light": "#fef9c3",
        "default": "#eab308",
        "dark": "#a16207"
      },
      "error": {
        "light": "#fee2e2",
        "default": "#ef4444",
        "dark": "#b91c1c"
      },
      "info": {
        "light": "#dbeafe",
        "default": "#3b82f6",
        "dark": "#1d4ed8"
      }
    },
    "theme": {
      "light": {
        "background": "#ffffff",
        "surface": "#fafafa",
        "surfaceRaised": "#ffffff",
        "border": "#e5e5e5",
        "borderStrong": "#d4d4d4",
        "textPrimary": "#171717",
        "textSecondary": "#525252",
        "textTertiary": "#737373",
        "textInverse": "#ffffff",
        "primaryBg": "#f5f3ff",
        "primaryText": "#7c3aed"
      },
      "dark": {
        "background": "#0a0a0a",
        "surface": "#171717",
        "surfaceRaised": "#262626",
        "border": "#262626",
        "borderStrong": "#404040",
        "textPrimary": "#fafafa",
        "textSecondary": "#a3a3a3",
        "textTertiary": "#737373",
        "textInverse": "#171717",
        "primaryBg": "#2e1065",
        "primaryText": "#c4b5fd"
      }
    }
  },

  "typography": {
    "fontFamily": {
      "sans": "'Pretendard', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
      "mono": "'JetBrains Mono', 'SF Mono', 'Fira Code', monospace"
    },
    "fontSize": {
      "xs": "12px",
      "sm": "14px",
      "base": "16px",
      "lg": "18px",
      "xl": "20px",
      "2xl": "24px",
      "3xl": "30px",
      "4xl": "36px",
      "5xl": "48px",
      "6xl": "60px"
    },
    "fontWeight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "lineHeight": {
      "tight": 1.1,
      "snug": 1.2,
      "normal": 1.5,
      "relaxed": 1.6
    },
    "heading": {
      "h1": { "fontSize": "60px", "fontWeight": 700, "lineHeight": 1.1 },
      "h2": { "fontSize": "48px", "fontWeight": 700, "lineHeight": 1.2 },
      "h3": { "fontSize": "36px", "fontWeight": 600, "lineHeight": 1.2 },
      "h4": { "fontSize": "30px", "fontWeight": 600, "lineHeight": 1.3 },
      "h5": { "fontSize": "24px", "fontWeight": 600, "lineHeight": 1.3 },
      "h6": { "fontSize": "20px", "fontWeight": 500, "lineHeight": 1.4 }
    },
    "body": {
      "lg": { "fontSize": "18px", "fontWeight": 400, "lineHeight": 1.5 },
      "base": { "fontSize": "16px", "fontWeight": 400, "lineHeight": 1.5 },
      "sm": { "fontSize": "14px", "fontWeight": 400, "lineHeight": 1.5 },
      "xs": { "fontSize": "12px", "fontWeight": 400, "lineHeight": 1.5 }
    }
  },

  "spacing": {
    "0": "0px",
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "8": "32px",
    "10": "40px",
    "12": "48px",
    "16": "64px",
    "20": "80px",
    "24": "96px"
  },

  "borderRadius": {
    "none": "0px",
    "sm": "4px",
    "md": "8px",
    "lg": "12px",
    "xl": "16px",
    "2xl": "24px",
    "full": "9999px"
  },
  "borderRadiusDefault": "8px",

  "shadow": {
    "sm": "0 1px 2px rgba(0, 0, 0, 0.05)",
    "md": "0 4px 12px rgba(0, 0, 0, 0.08)",
    "lg": "0 8px 24px rgba(0, 0, 0, 0.12)"
  },

  "breakpoint": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px"
  },

  "zIndex": {
    "dropdown": 1000,
    "sticky": 1100,
    "overlay": 1200,
    "modal": 1300,
    "popover": 1400,
    "toast": 1500
  },

  "transition": {
    "fast": "150ms ease",
    "normal": "200ms ease",
    "slow": "300ms ease"
  },

  "component": {
    "button": {
      "sm": { "height": "32px", "paddingX": "12px", "fontSize": "14px", "iconSize": "16px" },
      "md": { "height": "40px", "paddingX": "16px", "fontSize": "14px", "iconSize": "20px" },
      "lg": { "height": "48px", "paddingX": "24px", "fontSize": "16px", "iconSize": "20px" }
    },
    "input": {
      "sm": { "height": "32px", "paddingX": "10px", "fontSize": "14px" },
      "md": { "height": "40px", "paddingX": "14px", "fontSize": "14px" },
      "lg": { "height": "48px", "paddingX": "16px", "fontSize": "16px" }
    },
    "avatar": {
      "xs": { "size": "24px", "radius": "8px" },
      "sm": { "size": "28px", "radius": "10px" },
      "md": { "size": "36px", "radius": "12px" },
      "lg": { "size": "48px", "radius": "16px" },
      "xl": { "size": "56px", "radius": "20px" }
    },
    "iconSize": {
      "sm": "16px",
      "md": "20px",
      "lg": "24px"
    },
    "checkbox": {
      "sm": { "size": "16px", "borderRadius": "4px", "iconSize": "12px" },
      "md": { "size": "20px", "borderRadius": "4px", "iconSize": "14px" }
    },
    "radio": {
      "sm": { "size": "16px" },
      "md": { "size": "20px" }
    },
    "toggle": {
      "sm": { "width": "36px", "height": "20px", "thumbSize": "16px" },
      "md": { "width": "44px", "height": "24px", "thumbSize": "20px" }
    },
    "select": {
      "sm": { "height": "32px", "paddingX": "10px", "fontSize": "14px" },
      "md": { "height": "40px", "paddingX": "14px", "fontSize": "14px" },
      "lg": { "height": "48px", "paddingX": "16px", "fontSize": "16px" }
    },
    "textarea": {
      "minHeight": "80px",
      "paddingX": "14px",
      "paddingY": "10px",
      "fontSize": "14px"
    },
    "modal": {
      "sm": { "width": "400px" },
      "md": { "width": "560px" },
      "lg": { "width": "720px" },
      "padding": "24px",
      "borderRadius": "12px",
      "overlayColor": "rgba(0, 0, 0, 0.5)"
    },
    "navbar": {
      "height": "56px",
      "paddingX": "24px",
      "mobileHeight": "48px",
      "mobilePaddingX": "16px"
    },
    "sidebar": {
      "width": "240px",
      "collapsedWidth": "64px",
      "paddingX": "12px",
      "paddingY": "16px",
      "itemHeight": "40px",
      "itemBorderRadius": "8px"
    },
    "tab": {
      "height": "40px",
      "paddingX": "16px",
      "fontSize": "14px",
      "gap": "0px"
    },
    "table": {
      "headerHeight": "44px",
      "rowHeight": "48px",
      "cellPaddingX": "16px",
      "cellPaddingY": "12px",
      "fontSize": "14px"
    },
    "pagination": {
      "buttonSize": "36px",
      "fontSize": "14px",
      "gap": "4px"
    },
    "skeleton": {
      "borderRadius": "8px",
      "baseColor": { "light": "#e5e5e5", "dark": "#262626" },
      "shimmerColor": { "light": "#f5f5f5", "dark": "#404040" },
      "animationDuration": "1.5s"
    },
    "spinner": {
      "sm": "16px",
      "md": "24px",
      "lg": "40px",
      "strokeWidth": "2.5px"
    }
  },

  "border": {
    "width": {
      "default": "1px",
      "strong": "1.5px"
    }
  },

  "opacity": {
    "disabled": 0.4,
    "overlay": 0.5,
    "hover": 0.08
  },

  "focus": {
    "ringWidth": "2px",
    "ringColor": "#7c3aed",
    "ringOffset": "2px"
  },

  "layout": {
    "container": {
      "sm": "640px",
      "md": "768px",
      "lg": "1024px",
      "xl": "1280px"
    },
    "grid": {
      "columns": 12,
      "gutter": {
        "mobile": "16px",
        "desktop": "24px"
      }
    },
    "minTouchTarget": "44px"
  },

  "icon": {
    "library": "Lucide Icons",
    "url": "https://lucide.dev",
    "sizes": {
      "sm": "16px",
      "md": "20px",
      "lg": "24px"
    },
    "strokeWidth": "1.75"
  },

  "state": {
    "hover": {
      "opacity": 0.85,
      "bgOverlay": "rgba(0, 0, 0, 0.04)"
    },
    "active": {
      "opacity": 0.75,
      "bgOverlay": "rgba(0, 0, 0, 0.08)"
    },
    "disabled": {
      "opacity": 0.4,
      "cursor": "not-allowed"
    },
    "focus": {
      "ring": "0 0 0 2px #ffffff, 0 0 0 4px #7c3aed"
    }
  }
}
